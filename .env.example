# ── LLM Provider Keys ──────────────────────────────────────────────────────
# OpenAI — primary provider. Set at least OPENAI_API_KEY.
# Additional keys (_2, _3, _4) are tried on quota/rate-limit errors.
OPENAI_API_KEY=sk-...
OPENAI_API_KEY_2=sk-...
OPENAI_API_KEY_3=sk-...
OPENAI_API_KEY_4=sk-...

# Grok (xAI) — secondary provider. Used when all OpenAI keys fail.
GROK_API_KEY=xai-your-grok-api-key-here

# ── Model Overrides (optional) ────────────────────────────────────────────
OPENAI_MODEL=gpt-4.1-mini
GROK_MODEL=grok-2-latest
LLM_LOG_LEVEL=INFO

# ── Anthropic (optional) ──────────────────────────────────────────────────
# Enables claude-opus-4-5 as the evaluation judge in --mode eval
# If not set, the judge falls back to gpt-4o-mini via OPENAI_API_KEY
ANTHROPIC_API_KEY=sk-ant-...

# ── Qdrant Cloud vector database (RAG indexing) ──────────────────────────
# Get credentials from https://cloud.qdrant.io
QDRANT_URL=https://your-cluster.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key-here
COLLECTION_NAME=ai_scientist
