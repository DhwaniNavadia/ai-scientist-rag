# Path to the root of the autonomous-ai-scientist project (where run_pipeline.py lives)
PIPELINE_DIR=../

# Where the pipeline writes its output files
OUTPUTS_DIR=../outputs/

# Where uploaded PDFs are saved before being fed to the pipeline
INPUTS_DIR=../inputs/

# Comma-separated allowed CORS origins. Use * to allow everything (development only).
CORS_ORIGINS=*
